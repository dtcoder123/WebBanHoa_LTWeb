@{
    ViewBag.Title = "Liên Hệ Với Chúng Tôi";
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
}

<style>
    /* CSS tùy chỉnh cho Contact Page */
    .contact-container {
        padding: 60px 0;
        background-color: #f7f7f7; /* Màu nền nhẹ nhàng */
    }

    .contact-info {
        background-color: #4c6a4a; /* Màu xanh lá chủ đạo của cửa hàng hoa */
        color: white;
        padding: 40px;
        border-radius: 8px 0 0 8px; /* Bo tròn góc bên trái */
        height: 100%;
    }

        .contact-info h3 {
            border-bottom: 2px solid #a3c4a2; /* Đường kẻ phân cách */
            padding-bottom: 15px;
            margin-bottom: 30px;
        }

    .info-item i {
        font-size: 1.5rem;
        width: 30px;
        text-align: center;
    }

    .contact-form {
        background-color: white;
        padding: 40px;
        border-radius: 0 8px 8px 0; /* Bo tròn góc bên phải */
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Tạo bóng đổ nhẹ */
    }

    .form-control:focus {
        border-color: #4c6a4a;
        box-shadow: 0 0 0 0.2rem rgba(76, 106, 74, 0.25);
    }

    .btn-submit {
        background-color: #4c6a4a;
        border-color: #4c6a4a;
        transition: background-color 0.3s ease;
    }

        .btn-submit:hover {
            background-color: #6d9369;
            border-color: #6d9369;
        }

    .map-container {
        margin-top: 40px;
        border-radius: 8px;
        overflow: hidden;
    }
</style>

<div class="contact-container">
    <div class="container">
        <h1 class="text-center mb-5" style="color: #4c6a4a;">🌸 Liên Hệ Với Chúng Tôi 🌿</h1>

        <div class="row no-gutters">

            <div class="col-md-5">
                <div class="contact-info">
                    <h3>Thông Tin Liên Lạc</h3>

                    <div class="mb-4 info-item d-flex align-items-start">
                        <i class="fa-solid fa-location-dot me-3"></i>
                        <div>
                            <h5>Địa Chỉ</h5>
                            <p>123 Đường Nguyễn Huệ, Quận 1, TP. Hồ Chí Minh</p>
                        </div>
                    </div>

                    <div class="mb-4 info-item d-flex align-items-start">
                        <i class="fa-solid fa-envelope me-3"></i>
                        <div>
                            <h5>Email</h5>
                            <p>support@webbanhoa.com</p>
                        </div>
                    </div>

                    <div class="mb-4 info-item d-flex align-items-start">
                        <i class="fa-solid fa-phone me-3"></i>
                        <div>
                            <h5>Điện Thoại</h5>
                            <p>(028) 123 4567 | 0987 654 321</p>
                        </div>
                    </div>

                    <div class="mb-4 info-item d-flex align-items-start">
                        <i class="fa-solid fa-clock me-3"></i>
                        <div>
                            <h5>Giờ Làm Việc</h5>
                            <p>Thứ 2 - Chủ Nhật: 8:00 AM - 9:00 PM</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="contact-form">
                    <h3>Gửi Tin Nhắn Cho Chúng Tôi</h3>

                    @using (Html.BeginForm("Contact", "Home", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="HoTen" class="form-label">Họ tên của bạn</label>
                            <input type="text" class="form-control" id="HoTen" name="HoTen" required>
                        </div>

                        <div class="mb-3">
                            <label for="Email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="Email" name="Email" required>
                        </div>

                        <div class="mb-3">
                            <label for="TieuDe" class="form-label">Tiêu đề</label>
                            <input type="text" class="form-control" id="TieuDe" name="TieuDe" required>
                        </div>

                        <div class="mb-3">
                            <label for="NoiDung" class="form-label">Nội dung tin nhắn</label>
                            <textarea class="form-control" id="NoiDung" name="NoiDung" rows="4" required></textarea>
                        </div>

                        <button type="submit" class="btn btn-submit text-white w-100">Gửi Tin Nhắn</button>

                        if (ViewBag.Message != null)
                        {
                            <div class="alert alert-success mt-3" role="alert">
                                @ViewBag.Message
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="map-container">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.499696700813!2d106.69611597464082!3d10.77259165922379!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f207d571f37%3A0x6b4f7422f28e2190!2zTmd1eWVuIEh14buHLCBC4bq_biBOZ2jDqSwgUXXhuq1uIDEsIFRwLiBI4buTIENow60gTWluaA!5e0!3m2!1svi!2s!4v1700000000000!5m2!1svi!2s"
                    width="100%"
                    height="450"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </div>
</div>
