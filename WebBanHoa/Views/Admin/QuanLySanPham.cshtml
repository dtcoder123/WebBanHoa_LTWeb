@model IEnumerable<WebBanHoa.Models.HOA>
@{
    ViewBag.Title = "Quản Lý Sản Phẩm Hoa";
    // Giữ nguyên Layout theo thiết lập của bạn
    Layout = "~/Views/Shared/_LayoutPageAdmin.cshtml";
}

<h2 class="mb-4">📋 @ViewBag.Title</h2>

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Danh Sách Hoa</h4>
        <a href="@Url.Action("ThemSanPham", "Admin")" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Thêm Hoa Mới
        </a>
    </div>

    <div class="card-body">
        <div id="alertPlaceholder">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Mã Hoa</th>
                        <th>Hình Ảnh</th>
                        <th>Tên Hoa</th>
                        <th>Loại</th>
                        <th>Giá</th>
                        <th>Tồn Kho</th>
                        <th>Trạng Thái</th>
                        <th style="width: 150px;">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaHoa</td>
                            <td>
                                <img src="@item.HinhAnh" alt="@item.TenHoa" style="height: 50px; width: auto; object-fit: cover;" />
                            </td>
                            <td>@item.TenHoa</td>
                            <td>@(item.LOAIHOA.TenLoai)</td>

                            <td>@Html.Raw(item.Gia.ToString("N0") + " VNĐ")</td>

                            <td>@item.SoLuongTon</td>

                            <td>
                                @{
                                    var isAvailable = item.SoLuongTon > 0;
                                    var statusText = isAvailable ? "Còn hàng" : "Hết hàng";
                                    var badgeClass = isAvailable ? "bg-success" : "bg-danger";
                                }
                                <span class="badge @badgeClass">@statusText</span>
                            </td>
                            <td>
                                <a href="@Url.Action("SuaSanPham", "Admin", new { id = item.MaHoa })" class="btn btn-sm btn-info me-1" title="Sửa"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-danger btn-delete" data-id="@item.MaHoa" title="Xóa"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.btn-delete').click(function () {
                var maHoa = $(this).data('id');
                var $row = $(this).closest('tr');
                var $alert = $('#alertPlaceholder');

                if (confirm('Bạn có chắc chắn muốn xóa sản phẩm [' + maHoa + '] này không?')) {

                    $.post('@Url.Action("XoaSanPham", "Admin")', { id: maHoa })
                        .done(function (response) {
                            $alert.empty();

                            if (response.success) {
                                $row.fadeOut(500, function() {
                                    $(this).remove();
                                });
                                $alert.append('<div class="alert alert-success">' + response.message + '</div>');
                            } else {
                                $alert.append('<div class="alert alert-danger">Lỗi xóa: ' + response.message + '</div>');
                            }
                        })
                        .fail(function (xhr, status, error) {
                            $alert.empty();
                            $alert.append('<div class="alert alert-danger">Lỗi kết nối server (Status: ' + xhr.status + '). Vui lòng kiểm tra lại Route hoặc Controller.</div>');
                            console.error("AJAX Error:", xhr.responseText, status, error);
                        });
                }
            });
        });
    </script>
}
