@model List<WebBanHoa.Models.HOA>
@{
    ViewBag.Title = "Sản Phẩm Hoa Tươi";
    Layout = "~/Views/Shared/_LayoutPage.cshtml";

    // --- Bổ sung các biến từ ViewBag cho Paging/Filter/Sort ---
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentMaLoai = ViewBag.MaLoai; // Lấy từ Controller
    string currentSort = ViewBag.Sort;     // Lấy từ Controller
    int totalItems = ViewBag.TotalItems ?? 0;
}

<style>

    /* Định nghĩa màu xanh đậm chính */
    :root {
        --primary-green-dark: #008000;
        --secondary-green-light: #13a31f;
        --hover-green: #006400;
        --price-red: #dc3545;
        --background-light: #f9f9f9;

    }



    /* Tiêu đề chung */
            h2 {
                        color: var(--primary-green-dark);
                        font-weight: 600;
                        padding-bottom: 10px;
                        border-bottom: 2px solid #eee;

    }



    /* Thẻ Sản phẩm */
            .card {
                        border-radius: 12px;
                        transition: transform 0.3s ease, box-shadow 0.3s ease;
                        overflow: hidden;
                        border: 1px solid #e0e0e0;
 
    }

                    .card:hover {
                                transform: translateY(-5px);
                                box-shadow: 0 12px 25px rgba(0, 128, 0, 0.2); /* Shadow màu xanh lá khi hover */
    }



    /* Ảnh Sản phẩm */
            .card-img-top {
                        height: 250px;
                        object-fit: cover;
                        border-bottom: 1px solid #f0f0f0;
    }

            .no-image {
                        height: 250px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        background-color: #f8f9fa;
                        color: #6c757d;
                        font-style: italic;
    }



    /* Nội dung Card */
            .card-body {
                        padding: 15px;
                        text-align: left;
    }

            .card-title {
                        color: var(--primary-green-dark) !important;
                        font-size: 1.25rem;
                        font-weight: bold;
                        height: 60px;
                        overflow: hidden;
                        margin-bottom: 10px;
    }

            .card-text .price-tag {
                        color: var(--price-red);
                        font-size: 1.1rem;
                        font-weight: 700;
                        margin-left: 5px;
    }

            .card-text.small {
                        font-size: 0.85rem;
                        color: #6c757d;
                        line-height: 1.4;
    }



    /* Nút */
            .btn-primary {
                        background-color: var(--primary-green-dark);
                        border-color: var(--primary-green-dark);
                        transition: background-color 0.2s;
    }

                    .btn-primary:hover {
                                background-color: var(--hover-green);
                                border-color: var(--hover-green);
    }

            .btn-outline-info {
                        color: var(--secondary-green-light);
                        border-color: var(--secondary-green-light);
    }

                .btn-outline-info:hover {
                            background-color: var(--secondary-green-light);
                            color: white;
    }



    /* Style cho Sidebar Filter */
            .filter-sidebar {
                        background-color: var(--background-light);
                        padding: 20px;
                        border-radius: 12px;
                        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

                    .filter-sidebar h5 {
                                color: var(--primary-green-dark);
                                font-weight: bold;
                                margin-bottom: 15px;
                                border-bottom: 2px solid #e0e0e0;
                                padding-bottom: 8px;
    }

            .list-group-item {
                        border: none;
                        border-radius: 8px;
                        margin-bottom: 5px;
                        transition: background-color 0.2s, color 0.2s;
                        font-weight: 500;
    }

                .list-group-item:hover, .list-group-item.active {
                            background-color: var(--secondary-green-light);
                            color: white;
    }

                .list-group-item.active {
                            border-color: var(--secondary-green-light);
    }
</style>

<h2 class="text-center mb-4">💐 Danh Sách Sản Phẩm Hoa</h2>
<div class="container-fluid">
    <div class="row">

        <!-- Cột Phân loại (Sidebar) -->
        <div class="col-lg-3 col-md-12 mb-4">
            <div class="filter-sidebar">
                <h5><i class="bi bi-tags-fill"></i> PHÂN LOẠI SẢN PHẨM</h5>
                <div class="list-group">
                    <!-- Link xem tất cả. Khi đổi Filter, luôn reset page=1 -->
                    <a href="/Flower?sort=@currentSort&page=1"
                                         class="list-group-item list-group-item-action @(string.IsNullOrEmpty(currentMaLoai) ? "active" : "")">
                        Tất Cả Sản Phẩm
                    </a>

                    <!-- Danh sách các loại hoa (Thêm &page=1 để reset trang khi đổi filter) -->
                    <a href="/Flower?MaLoai=L001&sort=@currentSort&page=1"
                                         class="list-group-item list-group-item-action @(currentMaLoai == "L001" ? "active" : "")">
                        Hoa Hồng 
                    </a>
                    <a href="/Flower?MaLoai=L002&sort=@currentSort&page=1"
                                         class="list-group-item list-group-item-action @(currentMaLoai == "L002" ? "active" : "")">
                        Hoa Ly 
                    </a>
                    <a href="/Flower?MaLoai=L003&sort=@currentSort&page=1"
                                         class="list-group-item list-group-item-action @(currentMaLoai == "L003" ? "active" : "")">
                        Hoa Lan
                    </a>
                    <a href="/Flower?MaLoai=L004&sort=@currentSort&page=1"
                                         class="list-group-item list-group-item-action @(currentMaLoai == "L004" ? "active" : "")">
                        Hoa Tulip
                    </a>
                    <a href="/Flower?MaLoai=L005&sort=@currentSort&page=1"
                                         class="list-group-item list-group-item-action @(currentMaLoai == "L005" ? "active" : "")">
                        Hoa Baby
                    </a>
                    <a href="/Flower?MaLoai=L006&sort=@currentSort&page=1"
                                         class="list-group-item list-group-item-action @(currentMaLoai == "L006" ? "active" : "")">
                        Hoa Cúc
                    </a>
                </div>
            </div>
        </div>

        <!-- Cột Danh sách Sản phẩm -->
        <div class="col-lg-9 col-md-12">

            <!-- Khu vực Sắp xếp (Sort) - Đã thêm hiển thị thông tin Paging -->
            <div class="d-flex justify-content-between align-items-center mb-4 p-2 bg-light rounded shadow-sm">
                <!-- Hiển thị thông tin phân trang -->
                <p class="mb-0 text-muted small">
                    Đang hiển thị @Model.Count sản phẩm.
                    @if (totalItems > 0)
                    {
                        <span>(Trang <strong>@currentPage</strong> / <strong>@totalPages</strong>)</span>
                    }
                    Tổng cộng: <strong>@totalItems</strong> sản phẩm.
                </p>

                <!-- Dropdown Sắp xếp -->
                <div class="d-flex align-items-center">
                    <label for="sortDropdown" class="me-2 text-muted d-none d-sm-inline">Sắp xếp theo:</label>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                                        type="button" id="sortDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            @(currentSort == "price_asc" ? "Giá Tăng Dần" :
                          currentSort == "price_desc" ? "Giá Giảm Dần" :
                          currentSort == "stock_desc" ? "Tồn Kho Nhiều Nhất" : "Mặc định")
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="sortDropdown">
                            <li>
                                <!-- Khi đổi Sắp xếp, Reset Page về 1 -->
                                <a class="dropdown-item @(string.IsNullOrEmpty(currentSort) ? "active" : "")"
                                                              href="/Flower?MaLoai=@currentMaLoai&page=1">Mặc định (Theo Tên/Mã)</a>
                            </li>
                            <li>
                                <!-- Khi đổi Sắp xếp, Reset Page về 1 -->
                                <a class="dropdown-item @(currentSort == "price_asc" ? "active" : "")"
                                                              href="/Flower?MaLoai=@currentMaLoai&sort=price_asc&page=1">Giá Tăng Dần</a>
                            </li>
                            <li>
                                <!-- Khi đổi Sắp xếp, Reset Page về 1 -->
                                <a class="dropdown-item @(currentSort == "price_desc" ? "active" : "")" href="/Flower?MaLoai=@currentMaLoai&sort=price_desc&page=1">Giá Giảm Dần</a>
                            </li>
                            <!-- Đã thêm option sắp xếp Tồn Kho -->
                            <li>
                                <!-- Khi đổi Sắp xếp, Reset Page về 1 -->
                                <a class="dropdown-item @(currentSort == "stock_desc" ? "active" : "")" href="/Flower?MaLoai=@currentMaLoai&sort=stock_desc&page=1">Tồn Kho Nhiều Nhất</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Khu vực Sản phẩm -->
            <div class="row">
                @if (Model != null && Model.Any())
                {
                    foreach (var hoa in Model)
                    {
                        <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                            <div class="card h-100 shadow-sm">

                                <!-- Khu vực Ảnh -->
                                <div class="card-img-top-container">
                                    @if (!string.IsNullOrEmpty(hoa.HinhAnh))
                                    {
                                        <img src="@hoa.HinhAnh" class="card-img-top" alt="@hoa.TenHoa" onerror="this.onerror=null;this.src='https://placehold.co/400x250/ccc/333?text=Khong+co+anh';" />
                                    }
                                    else
                                    {
                                        <div class="no-image">
                                            <p class="text-muted">Không có ảnh</p>
                                        </div>
                                    }
                                </div>

                                <!-- Khu vực Nội dung -->
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@hoa.TenHoa</h5>
                                    <p class="card-text mb-1">
                                        <strong>Mã:</strong> @hoa.MaHoa
                                        <br />
                                        <strong>Giá:</strong> <span class="price-tag">@string.Format("{0:N0}", hoa.Gia) VNĐ</span>
                                        <br />
                                        <strong>Tình trạng:</strong>
                                        @{
                                    // Giả định trạng thái dựa trên SoLuongTon (Giả sử: > 10 là Còn hàng, 1-10 là Sắp hết, 0 là Hết hàng)
                                    string trangThai = hoa.SoLuongTon > 10 ? "Còn hàng" : (hoa.SoLuongTon > 0 ? "Sắp hết" : "Hết hàng");
                                    string trangThaiClass = hoa.SoLuongTon > 10 ? "text-success" : (hoa.SoLuongTon > 0 ? "text-warning" : "text-danger");
                                        }
                                        <span class="@trangThaiClass">
                                            @trangThai
                                        </span>
                                    </p>

                                    <!-- Mô tả cắt ngắn -->
                                    <p class="card-text small flex-grow-1 mt-2">
                                        @(hoa.MoTa != null && hoa.MoTa.Length > 100 ? hoa.MoTa.Substring(0, 100) + "..." : hoa.MoTa)
                                    </p>

                                    <!-- Nút hành động -->
                                    <div class="mt-3">
                                        <a href="/Flower/Details/@hoa.MaHoa" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye-fill"></i> Xem Chi Tiết
                                        </a>
                                        <!-- Giả định link Thêm vào Giỏ -->
                                        <a href="/Cart/AddToCart?MaHoa=@hoa.MaHoa&quantity=1" class="btn btn-sm btn-primary float-end">
                                            <i class="bi bi-cart-plus-fill"></i> Thêm vào Giỏ
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-warning text-center" role="alert">
                            <h4 class="alert-heading">⚠️ Không tìm thấy sản phẩm nào.</h4>
                            <p>Vui lòng kiểm tra lại dữ liệu trong bảng HOA hoặc điều chỉnh bộ lọc.</p>
                        </div>
                    </div>
                }
            </div>

            <!-- Khu vực PHÂN TRANG -->
            @if (totalPages > 1)
            {
                <div class="row mt-4 mb-5">
                    <div class="col-12 d-flex justify-content-center">
                        <nav aria-label="Phân trang sản phẩm">
                            <ul class="pagination shadow-sm rounded-pill">

                                <!-- Nút Previous -->
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link"
                                                           href="/Flower?MaLoai=@currentMaLoai&sort=@currentSort&page=@(currentPage - 1)"
                                                           aria-label="Trước">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                </li>

                                @for (int i = 1; i <= totalPages; i++)
                                {
                                   
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link"
                                                                 href="/Flower?MaLoai=@currentMaLoai&sort=@currentSort&page=@i">@i</a>
                                                            </li>
                                }

                                <!-- Nút Next -->
                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link"
                                                           href="/Flower?MaLoai=@currentMaLoai&sort=@currentSort&page=@(currentPage + 1)"
                                                           aria-label="Sau">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        </div>
    </div>
</div>