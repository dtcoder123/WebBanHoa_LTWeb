@model List<WebBanHoa.Models.HOA>
@{
    ViewBag.Title = "Sản Phẩm Hoa Tiêu Biểu";
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
}

<style>
       .banner {
           box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
           margin-bottom: 20px;
       }

       /* Thanh trang chủ */
       .banner-child {
           display: flex;
           justify-content: start;
           list-style: none;
           padding: 10px 0px;
           margin: 0;
       }

           .banner-child a {
               text-decoration: none;
               color: black;
           }

           .banner-child span {
               color: orange;
           }

       .row {
           max-width: 1279px;
           width: 100%;
       }

       /* Tiêu đề Hoa cưới */
       .title h1 {
           text-align: center;
           font-size: 30px;
           margin: 0;
           height: 40px;
       }

       .title {
           margin-bottom: 10px;
       }

       /* Phần sản phẩm  */
       .products-collection {
           margin: 0px 0px 40px 0px;
           padding: 0px 10px !important;
       }

       .block {
           width: 100%;
           margin-top: 20px;
           box-sizing: border-box;
       }

       /* Thanh sắp xếp */
       .sort {
           max-width: 1230px;
           padding: 8px 14px;
           background-color: #f1f1f1;
           border-radius: 12px;
           display: flex;
           justify-content: space-between;
           align-items: center;
       }

       /* nút filter  */
       .filter {
           width: fit-content;
           position: relative;
       }

       .btn-filter {
           background-color: #f1f1f1;
           border: 1px solid rgba(128, 128, 128, 0.336);
           border-radius: 5px;
           padding: 5px 10px;
       }

           .btn-filter:hover {
               background-color: #4c6a4a;
               color: white;
           }

       .fa-filter {
           margin-right: 5px;
           width: 18px;
           height: 18px;
       }

       .count-filter {
           position: absolute;
           top: -5px;
           left: -5px;
           background-color: orange;
           color: white;
           width: 16px;
           height: 16px;
           border-radius: 50%;
           font-size: 12px;
           font-weight: bold;
           display: inline-block;
           line-height: 16px;
           text-align: center;
           cursor: pointer;
           z-index: 1;
       }

       /* các nút sắp xếp */
       .sort-right {
           display: flex;
           justify-content: flex-end;
           align-items: center;
       }

       .fa-arrow-down-a-z {
           width: 22px;
           height: 22px;
       }

           .fa-arrow-down-a-z:not(:root) {
               overflow: hidden;
           }

       .sort-right h3 {
           font-size: 14px;
           float: left;
           margin: 0px;
           margin-right: 5px;
           font-weight: 500;
           display: flex;
           align-items: center;
       }

       .sort-right ul {
           list-style: none;
           margin-bottom: 0;
           padding-left: 0;
       }

       .sort-right li {
           float: left;
           padding: 0 0 0 10px;
       }

       .sort-right ul li a {
           display: block;
           padding: 4px 10px;
           font-size: 14px;
           border-radius: 8px;
           font-weight: 500;
           text-align: right;
           border: #ccc solid 1px;
           color: black;
           text-decoration: none;
           cursor: pointer;
       }

       .sort-right ul li {
           border: none;
       }

       .sort-right .active {
           background-color: #537453;
           border-color: #4c6a4a;
           color: white;
       }

       .sort-right li a:hover {
           background-color: #537453;
           border-color: #4c6a4a;
           color: white;
       }

       /* Hiện sản phẩm */
       /*    .fade-up {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 1.2s ease-out, transform 0.8s ease-out;
    }

        .fade-up::after {
            opacity: 1;
            transform: translateY(0);
        }*/

       .products-collection {
           margin-bottom: 40px;
       }

       .product-view {
           margin-top: 20px;
       }

           .product-view .row {
               margin-left: -10px;
               margin-right: -10px;
           }

       .item-product {
           display: block;
           height: 100%;
           padding-bottom: 20px;
           position: relative;
       }

           .item-product .product-block {
               background: #fff;
               border-radius: 10px;
               padding: 10px;
               height: 100%;
               overflow: hidden;
               box-shadow: 0px 0px 6px 0px rgba(50, 50, 93, 0.15), 1px 1px 5px rgba(0, 0, 0, 0.05);
               margin-bottom: 0px;
           }

               /* Phần bọc ảnh */
               .item-product .product-block .product-img {
                   width: 100%;
                   aspect-ratio: 1;
                   /*giữ tỉ lệ khung hình 1:1 */
                   position: relative;
                   margin-bottom: 12px;
               }

                   /* Ảnh  */
                   .item-product .product-block .product-img img {
                       width: auto;
                       height: 100%;
                       max-width: 100%;
                       position: absolute;
                       top: 0;
                       bottom: 0;
                       left: 0;
                       right: 0;
                       margin: auto;
                       object-fit: contain;
                       transition: transform 0.3s ease;
                       cursor: pointer;
                   }

                       .item-product .product-block .product-img img:hover {
                           transform: scale(1.03);
                       }

       .product-info .product-name {
           overflow: hidden;
           text-overflow: ellipsis;
       }

           .product-info .product-name h3 {
               font-size: 16px;
               margin-bottom: 5px;
               height: 50px;
               font-weight: 500;
           }

       #product-list .col-3 {
           padding-left: 10px;
           padding-right: 10px;
       }

       .product-price-cart {
           display: flex;
           justify-content: space-between;
           align-items: flex-end;
       }

       .price {
           color: #ea8725;
           font-weight: 800;
           width: 100%;
           font-size: 18px;
           line-height: initial;
           display: block;
       }

       .item-product .product-block .product-info .product-price-cart .btn-cart {
           color: #fff;
           background-color: #4c6a4a;
       }

       .item-product .product-block .product-info .product-price-cart button {
           width: 36px;
           height: 36px;
           display: flex;
           justify-content: center;
           align-items: center;
           border-radius: 5px;
           border: 0px;
           padding: 0px;
       }

       .card-title {
           cursor: pointer;
       }

       .item-product .product-block .product-info .product-price-cart button .fa-cart-plus {
           width: 22px;
           height: 22px;
           display: block;
       }

       .item-product .product-block .product-info .product-price-cart button:hover {
           background-color: #ea8725;
       }

       .item-product .product-block .product-info .product-name .card-title a {
           text-decoration: none;
           color: black;
       }

           .item-product .product-block .product-info .product-name .card-title a:hover {
               color: #ea8725;
           }

       .page-item a {
           border-radius: 5px;
           border: 1px solid #4c6a4a;
           color: #4c6a4a;
           margin-right: 5px;
       }

           .page-item a:hover {
               color: #4c6a4a;
           }

           .page-item a:active {
               background-color: #4c6a4a;
               color: white;
           }

       .auth-required-cart {
           position: relative; /* Quan trọng để định vị tooltip */
           display: inline-block;
           cursor: not-allowed; /* Thay đổi con trỏ chuột */
           z-index: 9999;
       }

           /* Vô hiệu hóa nút thực tế */
           .auth-required-cart .btn-cart.disabled {
               opacity: 0.6; /* Làm mờ nút */
               pointer-events: none; /* Cực kỳ quan trọng: Ngăn chặn click vào nút */
           }

           /* Ẩn Tooltip ban đầu */
           .auth-required-cart::before,
           .auth-required-cart::after {
               visibility: hidden;
               opacity: 0;
               pointer-events: none;
               transition: opacity 0.3s ease; /* Hiệu ứng mờ dần */
           }

           /* Nội dung Tooltip (Khung text) */
           .auth-required-cart::before {
               content: "Vui lòng đăng nhập"; /* TEXT BẠN MUỐN HIỂN THỊ */
               position: absolute;
               bottom: 100%; /* Đặt Tooltip lên trên nút */
               left: 0%;
               transform: translateX(-50%) translateY(5px); /* Đặt ở giữa và dịch chuyển nhẹ */
               /* Phong cách */
               background-color: #333;
               color: white;
               padding: 5px 10px;
               border-radius: 4px;
               white-space: nowrap;
               font-size: 12px;
               z-index: 10000;
           }

           /* Mũi tên Tooltip (Tùy chọn) */
           .auth-required-cart::after {
               content: "";
               position: absolute;
               bottom: 100%; /* Giống như khung text */
               left: 0%;
               transform: translateX(-50%) translateY(5px);
               margin-bottom: -5px; /* Điều chỉnh vị trí mũi tên */
               border-width: 5px;
               border-style: solid;
               border-color: #333 transparent transparent transparent; /* Tạo mũi tên trỏ xuống */
               z-index: 10003;
           }

           /* HIỆN TOOLTIP KHI HOVER */
           .auth-required-cart:hover::before,
           .auth-required-cart:hover::after {
               visibility: visible;
               opacity: 1;
               transform: translateX(-50%) translateY(-5px) translateZ(0); /* Dịch chuyển Tooltip nhẹ lên trên */
           }

       }

       .btnxem {
           display: flex;
           justify-content: center;
       }

       .XemTatCa {
           display: block;
           margin: 20px auto;
       }

           .XemTatCa .btn {
               background-color: #008000;
               border-color: #008000;
               color: white;
           }

               .XemTatCa .btn:hover {
                   background-color: #006400;
                   border-color: #006400;
                   color: white;
               }
</style>
<div class="layout-products">
    <h2 class="text-center mb-4 mt-4">✨ Sản Phẩm Tiêu Biểu</h2>
    <!-- Thanh Trang chủ điều hướng -->
    <div class="container">
        <!-- Phần chứa sản phẩm -->
        <div class="products-collection col-lg-12 col-12">
            <div class="product-view">
                <div class="row row-col-1 row-col-sm-2 row-col-md-3 row-col-lg-4" id="product-list">
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var hoa in Model)
                        {
                            <div class="col-3 fade-up">
                                <div class="item-product">
                                    <form class="product-block">
                                        <div class="product-img">
                                            @if (!string.IsNullOrEmpty(hoa.HinhAnh))
                                            {
                                                <img src="@Url.Content(hoa.HinhAnh)" class="card-img-top" alt="@hoa.TenHoa" />
                                            }
                                            else
                                            {
                                                <img src="https://bizweb.dktcdn.net/thumb/large/assets/themes_support/noimage.gif">
                                            }

                                        </div>
                                        <div class="product-info">
                                            <div class="product-name">
                                                <h3 class="card-title"><a href="@Url.Action("DetailHome", "Home", new { id = hoa.MaHoa })"> @hoa.TenHoa</a></h3>
                                            </div>
                                            <div class="product-price-cart">
                                                <div>
                                                    <span class="card-text price">@string.Format("{0:N0}", hoa.Gia) đ</span>
                                                </div>
                                                <div>
                                                    @using WebBanHoa.App_Start
                                                    @if (Session.IsLoggedIn())
                                                    {
                                                        <button type="button" class="btn-cart add-to-cart-ajax" data-image="@hoa.HinhAnh" data-name="@hoa.MoTa" data-price="@hoa.Gia" data-mahoa="@hoa.MaHoa" data-soluong="1">
                                                            <i class="fa-solid fa-cart-plus" style="margin-top: 5px"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <div class="auth-required-cart">
                                                            <button class="btn-cart disabled" type="button">
                                                                <i class="fa-solid fa-cart-plus" style="margin-top: 5px"></i>
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-center w-100">Không có sản phẩm nào để hiển thị.</p>
                    }
                </div>

            </div>
        </div>
        <div class="btnxem">
            <div class="XemTatCa">
                <a href="/Flower" class="btn btn-lg">
                    Xem tất cả
                </a>
            </div>
        </div>
    </div>
 </div>