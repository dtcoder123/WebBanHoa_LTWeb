@model List<WebBanHoa.Models.HOA>
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
}

<style>
    .banner-child {
        display: flex;
        justify-content: start;
        list-style: none;
        padding: 10px 0px;
        margin: 0;
    }

        .banner-child a {
            text-decoration: none;
            color: black;
        }

        .banner-child span {
            color: orange;
        }

    .row {
        max-width: 1279px;
        width: 100%;
    }
    .contain {
        display: flex;
        justify-content: center;
        margin-bottom: 50px;
    }
    .card {
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        padding: 30px;
        background-color: white;
    }

    h2 {
        font-size: 30px;
        font-weight: 600;
        color: #4CAF50;
        text-align: center;
    }

    form p {
        font-size: 14px;
        text-align: center;
    }

    form .form-group label {
        font-weight: bold;
        font-size: 14px;
    }

    form .form-group input {
        width: 100%;
        padding: 10px;
        margin: 8px 0;
        border-radius: 4px;
        border: 1px solid #ccc;
    }

        form .form-group input:focus {
            border-color: #4CAF50;
        }

    form .btn-block {
        margin-top: 10px;
        padding: 12px;
        border-radius: 4px;
        color: white;
        cursor: pointer;
    }

    form .btn-success {
        background-color: #4c6a4a;
    }

        form .btn-success:hover {
            background-color: #fd7e14;
        }

    form .btn-primary {
        background-color: #3b5998;
        color: white;
    }

    form .btn-danger {
        background-color: #db4437;
        color: white;
    }

    form .btn-primary:hover {
        background-color: #365899;
    }

    form .btn-danger:hover {
        background-color: #c1351d;
    }
    .d-flex button {
        flex: 1;
        font-size: 14px;
        padding: 10px;
        margin: 0 5px;
    }

        .d-flex button i {
            font-size: 18px; 
        }

    .btn-sm {
        width: 200px;
        font-size: 18px;
        padding: 8px;
        margin-right: 10px;
    }

    .mr-2 {
        margin-right: 8px;
    }
    .link-bar {
        display: flex;
        justify-content: space-between;
        margin-top: 12px;
        font-size: 14px;
    }

        .link-bar a {
            color: black;
            text-decoration: none;
        }

            .link-bar a:hover {
                color: #fd7e14;
                text-decoration: underline;
            }

    .or {
        text-align: center;
        margin: 15px 0;
        font-size: 14px;
    }
</style>
<body>
    <div class="layout-products">
        <!-- Thanh Trang chủ điều hướng -->
        <section class="banner">
            <div class="container">
                <ul class="banner-child">
                    <li class="home"><a href="#">Trang chủ > </a></li>
                    <li>
                        <span>
                            Đăng nhập tài khoản
                        </span>
                    </li>
                </ul>
            </div>
        </section>
        <div class="container">
            <div class="row justify-content-center mt-5 mb-5">
                <div class="col-md-6">
                    <div class="card p-4">
                        <h2 class="text-center text-success">ĐĂNG NHẬP</h2>
                        <form action="/Account/Login" method="POST">
                            <div class="form-group">
                                <label for="tendangnhap"></label>
                                <input type="text" class="form-control" id="tdn" name="tdn" placeholder="ten dang nhap" required>
                            </div>
                            <div class="form-group">
                                <label for="Email"></label>
                                <input type="Email" class="form-control" id="Email" name="Email" placeholder="Email" required>
                            </div>
                            <div class="form-group">
                                <label for="password"></label>
                                <input type="password" class="form-control" id="password" name="password" placeholder="Nhập mật khẩu" required>
                            </div>
                            <div class="form-group">
                                <input type="submit" value="Đăng nhập" class="btn btn-success btn-block">
                            </div>
                            <div class="link-bar">
                                <a href="#">Quên mật khẩu?</a>
                                <a href="/Account/Register">Đăng ký tại đây</a>
                            </div>
                            <p class="text-center">Hoặc đăng nhập bằng</p>
                            <div class="d-flex justify-content-center">
                                <!-- Nút Facebook -->
                                <div type="button" class="btn btn-primary btn-sm d-flex align-items-center justify-content-center">
                                    <a href="https://www.facebook.com/" style="text-decoration: none;color: white"><i class="fab fa-facebook-f mr-2"></i>Facebook</a>
                                </div>
                                <!-- Nút Google -->
                                <div type="button" class="btn btn-danger btn-sm d-flex align-items-center justify-content-center">
                                    <a href="https://byvn.net/Zi1a" style="text-decoration: none;color: white"><i class="fab fa-google mr-2"></i>Google</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>