@model WebBanHoa.Models.HOA
@{
    ViewBag.Title = Model.TenHoa;
    Layout = "~/Views/Shared/_LayoutPage.cshtml";
    string defaultImage = Url.Content("~/Content/images/no-image.png");
}

<div class="container py-5">
    <div class="row">
        <!-- Ảnh sản phẩm -->
        <div class="col-md-6 text-center">
            <img src="@Model.HinhAnh"
                 alt="@Model.TenHoa"
                 class="img-fluid rounded shadow-sm"
                 style="max-height: 500px; object-fit: cover;" />
        </div>

        <!-- Thông tin sản phẩm -->
        <div class="col-md-6">
            <h1 class="fw-bold mb-3">@Model.TenHoa</h1>
            <h3 class="text-danger fw-bold mb-3">
                @String.Format("{0:N0} đ", Model.Gia)
            </h3>

            <p class="mb-3">
                <strong>Trạng thái:</strong>
                @if (Model.TrangThai == "Còn hàng")
                {
                    <span class="badge bg-success">@Model.TrangThai</span>
                }
                else
                {
                    <span class="badge bg-secondary">@Model.TrangThai</span>
                }
            </p>

            <p><strong>Số lượng tồn kho:</strong> @Model.SoLuongTon</p>

            <p class="mt-4">@Html.Raw(Model.MoTa.Replace("\n", "<br/>"))</p>

            <div class="mt-4 d-flex align-items-center">
                <label class="me-2 fw-semibold">Số lượng:</label>
                <input type="number" id="quantity" value="1" min="1" max="@Model.SoLuongTon"
                       class="form-control d-inline-block" style="width: 80px;" />
            </div>

            <div class="mt-4">
                <a href="@Url.Action("AddToCart", "Cart", new { id = Model.MaHoa })"
                   class="btn btn-danger btn-lg me-3">
                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                </a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left"></i> Quay lại cửa hàng
                </a>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <!-- Mô tả chi tiết -->
    <div class="row">
        <div class="col-md-12">
            <h4 class="fw-bold mb-3">🌸 Mô tả sản phẩm</h4>
            <p style="font-size: 1.1rem; line-height: 1.7;">
                @Html.Raw(Model.MoTa)
            </p>
        </div>
    </div>
    <!-- Chính sách hỗ trợ & cam kết -->
    <div class="row">
        <div class="col-md-12">
            <h4 class="fw-bold mb-3">Chính sách hỗ trợ & Cam kết</h4>
            <div class="mb-4">
                <h5>1. Giao hàng</h5>
                <ul>
                    <li>Hỗ trợ giao hàng nội thành TP.HCM và các khu vực lân cận trong vòng 4-6 giờ kể từ khi xác nhận đơn hàng.</li>
                    <li>Dịch vụ giao nhanh trong khoảng 2 giờ dành cho khu vực trung tâm.</li>
                    <li>Phí vận chuyển được tính dựa theo khu vực và thời gian giao.</li>
                    <li>Quý khách vui lòng cung cấp địa chỉ chi tiết và số điện thoại liên hệ để đảm bảo giao hàng đúng giờ.</li>
                </ul>
            </div>
            <div class="mb-4">
                <h5>2. Đổi trả & Hoàn tiền</h5>
                <ul>
                    <li>Trường hợp sản phẩm nhận được bị sai mẫu mã, thiếu số lượng hoặc hư hỏng ngoài ý muốn, quý khách có thể yêu cầu đổi trả hoặc hoàn tiền.</li>
                    <li>Thời gian yêu cầu đổi trả: trong vòng 2 giờ kể từ khi nhận hàng.</li>
                    <li>Sau khi nhận được phản hồi từ khách hàng, chúng tôi sẽ xử lý nhanh chóng: đổi sản phẩm mới hoặc hoàn tiền tùy trường hợp.</li>
                </ul>
            </div>
            <div class="mb-4">
                <h5>3. Cam kết chất lượng</h5>
                <ul>
                    <li>Sản phẩm đến tay khách hàng sẽ đúng mẫu, đúng chủng loại, số lượng và màu sắc như mô tả trên website.</li>
                    <li>Hoa được bảo quản và vận chuyển trong điều kiện tốt, đảm bảo còn tươi, không héo hoặc hư hỏng khi giao.</li>
                    <li>Nếu dịch vụ hoặc sản phẩm không đạt chuẩn như cam kết, chúng tôi chịu trách nhiệm hỗ trợ và giải quyết để đảm bảo quyền lợi khách hàng.</li>
                </ul>
            </div>
            <div class="mb-4">
                <h5>4. Hỗ trợ sau bán hàng & chăm sóc khách hàng</h5>
                <ul>
                    <li>Hỗ trợ tư vấn, chăm sóc khách hàng trước và sau khi mua hàng.</li>
                    <li>Mọi thắc mắc, khiếu nại vui lòng liên hệ qua hotline hoặc email của cửa hàng. Chúng tôi cam kết phản hồi nhanh và xử lý kịp thời các phản ánh.</li>
                </ul>
            </div>
            <div class="mb-4">
                <h5>5. Hiệu lực và điều khoản áp dụng</h5>
                <ul>
                    <li>Chính sách này có hiệu lực kể từ ngày đăng tải và áp dụng cho tất cả giao dịch mua hàng trên website/cửa hàng.</li>
                    <li>Việc đặt hàng và thanh toán đồng nghĩa khách hàng đã đọc, hiểu và đồng ý với chính sách này.</li>
                    <li>Chúng tôi có quyền cập nhật, thay đổi chính sách và sẽ thông báo đến khách hàng trong trường hợp có sửa đổi đáng kể.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    h1, h4 {
        font-family: 'Playfair Display', serif;
    }

    .btn-danger {
        background-color: #d6336c;
        border-color: #d6336c;
    }

        .btn-danger:hover {
            background-color: #c8235a;
            border-color: #c8235a;
        }
</style>